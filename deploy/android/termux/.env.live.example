# Live API runtime
LIVE_API_HOST=127.0.0.1
LIVE_API_PORT=8010
LIVE_API_REQUIRE_AUTH=true
LIVE_API_AUTH_TOKEN=change_me_live_token
LIVE_API_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost

# Live engine persistence
LIVE_ROBOT_STORE_PATH=.cache/live/robots.json
LIVE_ROBOT_STORE_MAX_ROBOTS=200
LIVE_ROBOT_STORE_MAX_EVENTS=1000

# Exchange credentials
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_RECV_WINDOW_MS=10000
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com

# Mobile push (recommended on Android)
MOBILE_NOTIFY_ENABLED=true
MOBILE_NOTIFY_PROVIDER=ntfy
MOBILE_NOTIFY_TIMEOUT_SECONDS=8
MOBILE_NOTIFY_HEARTBEAT_MINUTES=15
MOBILE_NOTIFY_NTFY_BASE_URL=https://ntfy.sh
MOBILE_NOTIFY_NTFY_TOPIC=your_topic_here
MOBILE_NOTIFY_NTFY_TOKEN=
